# Backend Environment Variables
# Copy this file to .env and fill in your values

# ===== SERVER =====
PORT=5000
NODE_ENV=development

# ===== MONGODB =====
# Local: mongodb://localhost:27017/resume_analyser
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/resume_analyser
MONGODB_URI=mongodb://localhost:27017/resume_analyser

# ===== GOOGLE GEMINI =====
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here
# Primary text model. If it is overloaded, the backend will try the fallback list.
GOOGLE_MODEL_NAME=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-3.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro

# ===== PINECONE =====
# Get from: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here
# Create an index with dimension=768 and metric=cosine
PINECONE_INDEX_NAME=resume-analyser

# ===== FILE UPLOAD =====
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
